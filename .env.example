# 1. Project Settings
PROJECT_NAME="Smart Glass AI System"
VERSION="2.0.0"

# 2. AI Model API Keys
# OpenAI GPT-4o나 Whisper 등을 사용할 경우 필요합니다.
OPENAI_API_KEY=sk-xxxx...

# Java Auth Server(JWT)와 동일한 Base64 Secret
AUTH_JWT_SECRET_B64=dGhpcy1pcy1hLWRlbW8tamR0LXNlY3JldC1rZXktZm9yLWRldi0wMDEyMw==

# 회원가입(Sign Up) 인증 코드
# - /auth/register 요청의 companyAuthCode 값과 일치해야 가입 허용
# - companyName은 임의 문자열(빈 값 불가)
AUTH_SIGNUP_VERIFICATION_CODE=SG-DEMO-CODE-2026

# 3. Database Settings
# 현재 코드에서는 DB_HOST/DB_PORT/DB_NAME/DB_USER/DB_PASSWORD를 사용합니다.
DB_HOST=127.0.0.1
DB_PORT=3380
DB_NAME=smart_glass_dev
DB_USER=sg_app
DB_PASSWORD=sg_app_1

# 4. RAG & Vector DB Settings
# 로컬에 저장될 FAISS 인덱스 폴더 경로입니다.
VECTOR_DB_PATH=infrastructure/vector-db/faiss_index

# 5. Local File Storage
# 이미지/음성 자산 및 리포트가 저장될 서버 내 경로입니다.
REPORT_OUTPUT_DIR=storage/reports
ASSET_UPLOAD_DIR=storage/assets

# 6. Model Paths
# 로컬에 다운로드받은 Qwen 등의 모델 파일 경로입니다.
# QWEN_MODEL_PATH=models/Qwen-VL-Chat
PREDICTION_MODEL_DIR=models/weights
